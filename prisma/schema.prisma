generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  products           Product[]
  sales              Sale[]
  customers          Customer[]
  expenses           Expense[]
  shippingRates      ShippingRate[]
  settings           Setting[]
  stockLogs          StockLog[]
  orderStatusLogs    OrderStatusLog[]
  creditPayments     CreditPayment[]
  debtReminders      DebtReminder[]
  consultants        Consultant[]
  commissionPayments CommissionPayment[]
  consultantStock    ConsultantStock[]
  stockTransfers     StockTransfer[]
  salesTargets       SalesTarget[]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
}

model Product {
  id           String     @id @default(cuid())
  name         String
  sku          String
  description  String?
  category     String?
  costPrice    Decimal    @db.Decimal(10, 2)
  sellingPrice Decimal    @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)
  stock        Int        @default(0)
  reorderLevel Int        @default(5)
  supplier     String?
  imageUrl     String?
  isActive     Boolean    @default(true)
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  saleItems       SaleItem[]
  stockLogs       StockLog[]
  consultantStock ConsultantStock[]
  stockTransfers  StockTransfer[]

  @@unique([companyId, sku])
}

model StockLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  change    Int
  reason    String
  saleId    String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
}

model Sale {
  id              String           @id @default(cuid())
  orderNumber     String
  date            DateTime         @default(now())
  totalPrice      Decimal          @db.Decimal(10, 2)
  shippingCost    Decimal          @db.Decimal(10, 2) @default(0)
  shippingCharge  Decimal          @db.Decimal(10, 2) @default(0)
  discount        Decimal          @db.Decimal(10, 2) @default(0)
  status          String           @default("Pending")
  paymentStatus   String           @default("Unpaid")
  paymentMethod   String?
  source          String?
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  customerName    String?
  customerPhone   String?
  customerCity    String?
  deliveryAddress String?
  notes           String?
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  paymentType     String           @default("Cash")
  amountPaid      Decimal          @db.Decimal(10, 2) @default(0)
  creditDueDate   DateTime?
  creditNotes     String?
  consultantId    String?
  consultant      Consultant?      @relation(fields: [consultantId], references: [id])
  items           SaleItem[]
  statusHistory   OrderStatusLog[]
  creditPayments  CreditPayment[]
  debtReminders   DebtReminder[]

  @@unique([companyId, orderNumber])
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  sale         Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  qty          Int
  unitPrice    Decimal @db.Decimal(10, 2)
  costPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)
  serialNumber String?
  stockSourceConsultantId String?
  stockSourceConsultant   Consultant? @relation("StockSource", fields: [stockSourceConsultantId], references: [id])
}

model OrderStatusLog {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id])
  fromStatus String
  toStatus   String
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  whatsapp  String?
  city      String?
  email     String?
  source    String?
  notes     String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  sales     Sale[]
}

model Expense {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  description   String
  amount        Decimal  @db.Decimal(10, 2)
  category      String
  paymentMethod String?
  isRecurring   Boolean  @default(false)
  frequency     String?
  notes         String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model ShippingRate {
  id        String  @id @default(cuid())
  city      String
  region    String?
  rate      Decimal @db.Decimal(10, 2)
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, city])
}

model Setting {
  id        String  @id @default(cuid())
  key       String
  value     String
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
}

model CreditPayment {
  id            String   @id @default(cuid())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id])
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String?
  reference     String?
  notes         String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
}

model DebtReminder {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  channel   String
  message   String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  sentAt    DateTime @default(now())
}

model Consultant {
  id               String             @id @default(cuid())
  name             String
  phone            String?
  whatsapp         String?
  commissionRate   Decimal            @db.Decimal(10, 2) @default(50)
  tierThreshold    Int                @default(50)
  tierRate         Decimal            @db.Decimal(10, 2) @default(30)
  monthlyAllowance Decimal            @db.Decimal(10, 2) @default(400)
  isActive         Boolean            @default(true)
  notes            String?
  userId           String?            @unique
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  sales              Sale[]
  commissionPayments CommissionPayment[]
  stock              ConsultantStock[]
  stockTransfers     StockTransfer[]
  saleItemSources    SaleItem[]          @relation("StockSource")
}

model CommissionPayment {
  id            String     @id @default(cuid())
  consultantId  String
  consultant    Consultant @relation(fields: [consultantId], references: [id])
  amount        Decimal    @db.Decimal(10, 2)
  type          String     @default("commission")
  periodFrom    DateTime?
  periodTo      DateTime?
  paymentMethod String?
  reference     String?
  notes         String?
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  createdAt     DateTime   @default(now())
}

model ConsultantStock {
  id            String     @id @default(cuid())
  consultantId  String
  consultant    Consultant @relation(fields: [consultantId], references: [id])
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  qty           Int        @default(0)
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  updatedAt     DateTime   @updatedAt

  @@unique([consultantId, productId])
}

model StockTransfer {
  id            String     @id @default(cuid())
  consultantId  String
  consultant    Consultant @relation(fields: [consultantId], references: [id])
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  qty           Int
  direction     String     @default("to_consultant")
  notes         String?
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id])
  createdAt     DateTime   @default(now())
}

model SalesTarget {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  label         String?
  periodStart   DateTime
  periodEnd     DateTime
  revenueTarget Decimal  @db.Decimal(12, 2)
  savingsRate   Decimal  @default(0.25) @db.Decimal(5, 4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, periodStart, periodEnd])
}
